# DocMind 环境变量配置模板
# 复制此文件为 .env 并填入实际值

# 数据库配置
DB_URL=jdbc:postgresql://localhost:5432/docmind
DB_USERNAME=postgres
DB_PASSWORD=your_database_password

# JWT 配置（建议使用 Base64 编码的随机字符串）
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRATION=86400000

# 文件存储路径
DOCMIND_STORAGE_PATH=./docmind-storage

# AI 模型 API Key
DASHSCOPE_API_KEY=your_dashscope_api_key_here
